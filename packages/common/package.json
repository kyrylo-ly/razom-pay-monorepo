{
	"name": "@razom-pay/common",
	"version": "1.1.13",
	"description": "Core shared components for Razom Pay microservice ecosystem",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"postbuild": "rm -rf node_modules/@nestjs",
		"format": "prettier --write \"{src,lib,test}/**/*.ts\"",
		"test": "jest"
	},
	"devDependencies": {
		"@nestjs/common": "^11.1.18",
		"@nestjs/config": "^4.0.4",
		"@nestjs/microservices": "^11.1.18",
		"@razom-pay/core": "workspace:*",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.6.0",
		"jest": "^30.3.0",
		"prettier": "^3.8.1",
		"ts-jest": "^29.4.9",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"@nestjs/common": "^11",
		"@nestjs/config": "^4",
		"@nestjs/microservices": "^11"
	},
	"dependencies": {
		"@opentelemetry/auto-instrumentations-node": "^0.77.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
		"@opentelemetry/resources": "^2.8.0",
		"@opentelemetry/sdk-node": "^0.219.0",
		"@opentelemetry/semantic-conventions": "^1.41.1",
		"@razom-pay/contracts": "workspace:*",
		"@trivago/prettier-plugin-sort-imports": "6.0.2"
	}
}
